  "compilerOptions": {
    "target": "ES5",
    "rootDir": "./src",
    "outDir": "./build",
    "strict": true,
    "module": "commonjs",
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true
  },
  "exclude": ["tests", "node_modules"]
}